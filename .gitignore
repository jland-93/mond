models/
checkpoints/
# 단, 백엔드 ORM 모델 디렉토리는 코드의 일부 — 커밋 유지
!backend/app/models/
!backend/app/models/**
# 빌드 산출물은 negation 대상 X
backend/app/models/**/__pycache__/
backend/app/models/**/*.pyc

# Data files
data/
datasets/
*.csv
*.json
*.xml
!package.json
!package-lock.json
!tsconfig.json
# 백엔드 정적 시드(규제 카탈로그 등)는 코드의 일부 — 커밋 유지
!backend/app/data/
!backend/app/data/**
# 단, 빌드 산출물(__pycache__)은 negation 대상 X
backend/app/data/**/__pycache__/
backend/app/data/**/*.pyc

