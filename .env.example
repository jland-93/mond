# 🌙 Mond 환경 변수 예시
# `.env`로 복사한 뒤 본인 환경에 맞게 수정하세요.

# ─── 애플리케이션 ─────────────────────────────────────
APP_NAME=Mond
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ─── API ────────────────────────────────────────────
# 운영 배포 시 반드시 충분히 긴 임의 값으로 교체하세요.
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── 데이터베이스 ─────────────────────────────────────
# docker-compose 사용 시 host를 `postgres`로 변경하세요.
DATABASE_URL=postgresql+asyncpg://mond:mond@localhost:5432/mond

# ─── Redis (Celery broker + 캐시) ──────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── 스캔 큐 (Celery) — 운영 안정성 옵션 ─────────────
# true면 인라인 동기 실행 대신 worker가 비동기 처리. 별도 worker 컨테이너 필요.
SCAN_QUEUE_ENABLED=false
# REDIS_URL을 기본 사용. 분리하려면 명시.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ─── CORS ───────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ─── AI provider 추상화 ────────────────────────────────
# 사용자의 환경에 맞춰 한 줄로 전환. 키가 비면 기본 규칙 fallback으로 UI는 정상.
# 선택: anthropic / openai / bedrock / ollama
AI_PROVIDER=anthropic
AI_MAX_TOKENS=2048

# Anthropic (직접 API)
ANTHROPIC_API_KEY=
AI_MODEL_DEFAULT=claude-haiku-4-5-20251001
AI_MODEL_DEEP=claude-sonnet-4-6

# OpenAI / Azure OpenAI / OpenAI-compatible gateway
# OPENAI_BASE_URL은 Azure 또는 사내 게이트웨이 사용 시에만.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_DEEP=gpt-4o

# AWS Bedrock (IAM 자격으로 호출 — Anthropic on Bedrock만 지원)
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_DEFAULT=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MODEL_DEEP=anthropic.claude-3-5-sonnet-20241022-v2:0

# Ollama / vLLM (로컬 LLM — 폐쇄망·데이터 외부 유출 금지 조직용)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_DEFAULT=llama3.1:8b
OLLAMA_MODEL_DEEP=llama3.1:70b

# ─── 스캐너 바이너리 (없으면 stub 모드) ─────────────────────
SCANNER_TRIVY_BIN=trivy
SCANNER_SEMGREP_BIN=semgrep
SCANNER_NUCLEI_BIN=nuclei

# ─── 데모 ────────────────────────────────────────────
SEED_ON_STARTUP=true
PROMETHEUS_ENABLED=true

# ─── 알림 채널 (URL 비어있으면 no-op) ──────────────────
# Slack Incoming Webhook URL — Critical/High finding을 즉시 전송
SLACK_WEBHOOK_URL=
# 자체 시스템 수신용 (PagerDuty, Discord, Lark, 커스텀)
GENERIC_WEBHOOK_URL=
# 알림 임계치: critical / high / medium / low / info
NOTIFY_MIN_SEVERITY=high
# Daily Security Digest 전용 채널 — 비우면 SLACK_WEBHOOK_URL을 fallback으로 사용.
# 보안팀 채널을 finding 알림과 분리하고 싶을 때.
DIGEST_SLACK_WEBHOOK_URL=

# GitHub API 토큰 (선택) — PR comment 작성 + 사설 repo의 의존성 파일 fetch.
# 비우면 SBOM diff는 public repo만 동작하고 PR comment는 건너뜀.
GITHUB_TOKEN=

# ─── GitHub Webhook 검증 ─────────────────────────────
# GitHub Webhook 설정 시 Secret과 동일하게 맞추세요.
# 비어있으면 서명 검증 생략 (개발 편의)
GITHUB_WEBHOOK_SECRET=

# ─── i18n ───────────────────────────────────────────
# UI 초기 언어 — ko / en
DEFAULT_LOCALE=ko

# ─── SSO / RBAC ───────────────────────────────────────
# AUTH_MODE: "dev" (이메일만 입력하는 데모 로그인) / "sso" (SSO만 허용)
AUTH_MODE=dev

# 활성 OIDC provider 콤마 묶음 — 예: "keycloak,okta,google"
SSO_PROVIDERS=

# Keycloak
SSO_KEYCLOAK_ISSUER=
SSO_KEYCLOAK_CLIENT_ID=
SSO_KEYCLOAK_CLIENT_SECRET=

# Okta
SSO_OKTA_ISSUER=
SSO_OKTA_CLIENT_ID=
SSO_OKTA_CLIENT_SECRET=

# Google Workspace
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=

# SSO 콜백 후 리다이렉트할 프론트엔드 base URL
SSO_REDIRECT_BASE=http://localhost:3000

# 자동으로 ADMIN 역할을 부여할 이메일 콤마 묶음 (없으면 첫 가입자 1명이 ADMIN)
SSO_ADMIN_EMAILS=

# 세션 cookie — 운영(HTTPS)은 SESSION_SECURE=true 권장
SESSION_COOKIE=mond_session
SESSION_DAYS=7
SESSION_SECURE=false

# ─── MCP 서버 (Claude Desktop / Code 통합) ────────────
# 권장: stdio 모드 — `python -m mcp_server` 또는 docker exec.
# HTTP/SSE 마운트는 실험적이며 mcp 패키지 버전에 민감하므로 기본 비활성.
MCP_HTTP_ENABLED=false

# ─── 프론트엔드 ────────────────────────────────────────
VITE_API_URL=http://localhost:8000
